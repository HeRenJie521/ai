###############################################################

### [API Key] DeepSeek：阻塞式单轮会话
POST {{baseUrl}}/api/chat
X-API-Key: {{apiKey}}
Content-Type: application/json

{
  "provider": "DEEPSEEK",
  "mode": "deepseek-chat",
  "stream": false,
  "messages": [
    { "role": "user", "content": "你好，用一句话介绍 DeepSeek。" }
  ],
  "temperature": 0.7,
  "maxTokens": 256
}

### [API Key] DeepSeek：多轮会话（第一轮）
POST {{baseUrl}}/api/chat
X-API-Key: {{apiKey}}
Content-Type: application/json

{
  "provider": "DEEPSEEK",
  "mode": "deepseek-chat",
  "stream": false,
  "sessionId": "apikey-session-001",
  "userId": "apikey-user-001",
  "messages": [
    { "role": "user", "content": "我叫小红，请记住我的名字。" }
  ]
}

### [API Key] DeepSeek：多轮会话（第二轮，验证上下文）
POST {{baseUrl}}/api/chat
X-API-Key: {{apiKey}}
Content-Type: application/json

{
  "provider": "DEEPSEEK",
  "mode": "deepseek-chat",
  "stream": false,
  "sessionId": "apikey-session-001",
  "userId": "apikey-user-001",
  "messages": [
    { "role": "user", "content": "我叫什么名字？" }
  ]
}

