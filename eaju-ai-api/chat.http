### 直传上游 model：阻塞
POST {{baseUrl}}/api/chat
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "provider": "DEEPSEEK",
  "model": "deepseek-chat",
  "stream": false,
  "messages": [
    { "role": "user", "content": "1+1=?" }
  ]
}

### DeepSeek：流式（SSE，stream=true）
POST {{baseUrl}}/api/chat
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "provider": "DEEPSEEK",
  "mode": "deepseek-chat",
  "stream": true,
  "messages": [
    { "role": "user", "content": "用三句话介绍 Spring Boot。" }
  ]
}

### Qwen：流式（SSE，stream=true）
POST {{baseUrl}}/api/chat
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "provider": "QWEN",
  "mode": "qwen3.6-plus",
  "stream": true,
  "messages": [
    { "role": "user", "content": "流式输出这段介绍：什么是 REST。" }
  ]
}

###############################################################
### 以下为使用 API Key 鉴权的测试用例（X-API-Key header）
###############################################################

### [API Key] DeepSeek：阻塞式单轮会话
POST {{baseUrl}}/api/chat
X-API-Key: {{apiKey}}
Content-Type: application/json

{
  "provider": "DEEPSEEK",
  "mode": "deepseek-chat",
  "stream": false,
  "messages": [
    { "role": "user", "content": "你好，用一句话介绍 DeepSeek。" }
  ],
  "temperature": 0.7,
  "maxTokens": 256
}

### [API Key] DeepSeek：多轮会话（第一轮）
POST {{baseUrl}}/api/chat
X-API-Key: {{apiKey}}
Content-Type: application/json

{
  "provider": "DEEPSEEK",
  "mode": "deepseek-chat",
  "stream": false,
  "sessionId": "apikey-session-001",
  "userId": "apikey-user-001",
  "messages": [
    { "role": "user", "content": "我叫小红，请记住我的名字。" }
  ]
}

### [API Key] DeepSeek：多轮会话（第二轮，验证上下文）
POST {{baseUrl}}/api/chat
X-API-Key: {{apiKey}}
Content-Type: application/json

{
  "provider": "DEEPSEEK",
  "mode": "deepseek-chat",
  "stream": false,
  "sessionId": "apikey-session-001",
  "userId": "apikey-user-001",
  "messages": [
    { "role": "user", "content": "我叫什么名字？" }
  ]
}

### [API Key] Qwen：阻塞式单轮会话
POST {{baseUrl}}/api/chat
X-API-Key: {{apiKey}}
Content-Type: application/json

{
  "provider": "QWEN",
  "mode": "qwen3.6-plus",
  "stream": false,
  "messages": [
    { "role": "user", "content": "用中文简要介绍什么是大语言模型。" }
  ]
}

### [API Key] DeepSeek：流式会话（SSE）
POST {{baseUrl}}/api/chat
X-API-Key: {{apiKey}}
Content-Type: application/json

{
  "provider": "DEEPSEEK",
  "mode": "deepseek-chat",
  "stream": true,
  "messages": [
    { "role": "user", "content": "请用三句话介绍 Spring Boot。" }
  ]
}
